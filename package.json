{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sync:snapshots": "node scripts/sync-night-watch-snapshots.mjs",
    "build:sync": "npm run sync:snapshots && npm run build",
    "deploy:fly": "bash scripts/deploy-with-sync.sh",
    "auto:publish": "bash scripts/auto-sync-commit-deploy.sh",
    "nightwatch:publish": "bash scripts/night-watch-to-prod.sh",
    "verify:deploy": "node scripts/verify-night-watch-deploy.mjs",
    "security:audit": "npm audit && node security-audit.js",
    "security:headers": "curl -I https://mission-control-ryan.fly.dev/",
    "security:check": "npm run security:audit && npm run security:headers"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "puppeteer": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
